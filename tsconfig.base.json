{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["node", "bun"],
    "paths": {
      "@swoosh-dev/router": ["./packages/model-router/src/index.ts"],
      "@swoosh-dev/ai-sdk": ["./packages/ai-sdk/src/index.ts"],
      "@swoosh-dev/capabilities": ["./packages/capabilities/src/index.ts"],
      "@swoosh-dev/judge": ["./packages/judge/src/index.ts"],
      "@swoosh-dev/sdk": ["./packages/sdk/src/index.ts"]
    }
  }
}
