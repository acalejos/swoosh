{
  "name": "@swoosh/capabilities",
  "version": "0.1.0",
  "description": "Curated default model-capability dataset for @swoosh/router \u2014 models.dev enriched with features it doesn't carry (web_search, latency classes, quality scores).",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "refresh": "bun run scripts/build.ts",
    "build": "tsup src/index.ts --format esm --dts --clean --treeshake"
  },
  "dependencies": {
    "@swoosh/router": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/acalejos/swoosh.git",
    "directory": "packages/capabilities"
  },
  "homepage": "https://github.com/acalejos/swoosh#readme",
  "publishConfig": {
    "access": "public"
  }
}
