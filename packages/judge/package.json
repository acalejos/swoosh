{
  "name": "@semafore/judge",
  "version": "0.1.0",
  "description": "Dynamic routing policies for @semafore/router \u2014 classify the prompt with an LLM judge (structured output) and route accordingly.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --treeshake"
  },
  "dependencies": {
    "@semafore/router": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/acalejos/swoosh.git",
    "directory": "packages/judge"
  },
  "homepage": "https://github.com/acalejos/swoosh#readme",
  "publishConfig": {
    "access": "public"
  }
}
