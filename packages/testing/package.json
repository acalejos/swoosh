  "description": "Test utilities for @swoosh-dev/router — fake catalogs, recording mock providers, and a fluent plan-assertion chain. Framework-agnostic.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
