{
  "name": "@swoosh-dev/ai-sdk",
  "version": "0.1.1",
  "description": "Vercel AI SDK provider adapter for @swoosh-dev/router.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --treeshake"
  },
  "dependencies": {
    "@swoosh-dev/router": "workspace:*"
  },
  "peerDependencies": {
    "ai": ">=5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/acalejos/swoosh.git",
    "directory": "packages/ai-sdk"
  },
  "homepage": "https://github.com/acalejos/swoosh#readme",
  "publishConfig": {
    "access": "public"
  }
}
